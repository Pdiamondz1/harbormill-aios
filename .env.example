# Harbormill AIOS — Frontend environment
# Copy to `.env` and fill in YOUR client's Supabase project values.
# These are PUBLIC (anon) values, safe to ship to the browser. Never put
# service-role keys or AI provider keys here — those live as Supabase
# Edge Function secrets (see docs/client-setup.md).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
